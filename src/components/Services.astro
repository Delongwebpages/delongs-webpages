---
const services = [
  {
    title: "Single-page sites",
    price: "$1,000",
    description: "One beautiful page that introduces your business, shows your work, and drives calls. Perfect for trades, freelancers, and local services.",
    bullets: ["Custom design", "Mobile-perfect", "Contact form", "SEO-ready"],
  },
  {
    title: "Multi-page sites",
    price: "$1,000 / page",
    description: "Home, About, Services, Gallery, Contact — built as a connected experience, not a stack of templates. You decide how many pages.",
    bullets: ["Custom every page", "Photo galleries", "Service pages", "Blog optional"],
    featured: true,
  },
  {
    title: "Redesigns + rescues",
    price: "$1,000 / page",
    description: "Stuck on Wix, Squarespace, or a half-finished build? I rebuild it on modern, fast, ownable code — without losing your search rankings.",
    bullets: ["Migration handled", "SEO preserved", "Faster, cleaner", "You own it"],
  },
];
---

<section class="section" id="services">
  <div class="container-page">
    <div class="max-w-3xl">
      <span class="eyebrow reveal">What I build</span>
      <h2 class="reveal mt-6 text-4xl sm:text-5xl md:text-6xl font-display font-semibold">
        Three flavors. <span class="gradient-text">All built the same way:</span> by hand, fast as light.
      </h2>
    </div>

    <div class="mt-16 grid md:grid-cols-3 gap-5">
      {services.map((s) => (
        <div class={`reveal relative card p-7 flex flex-col ${s.featured ? "ring-1 ring-[var(--color-accent)] bg-gradient-to-b from-[rgba(124,92,255,0.08)] to-transparent" : ""}`}>
          {s.featured && (
            <div class="absolute -top-3 left-7 inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-[var(--color-accent)] text-[var(--color-bg)]">
              Most popular
            </div>
          )}
          <h3 class="text-2xl font-display font-semibold">{s.title}</h3>
          <p class="mt-2 text-sm font-mono text-[var(--color-accent-2)]">{s.price}</p>
          <p class="mt-4 text-[var(--color-fg-muted)] leading-relaxed flex-1">{s.description}</p>
          <ul class="mt-6 space-y-2 text-sm">
            {s.bullets.map((b) => (
              <li class="flex items-center gap-2">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-accent)] shrink-0" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
