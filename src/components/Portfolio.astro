---
// PLACEHOLDER projects — swap with real screenshots + URLs after launch
// Replace `image` with `/portfolio/your-screenshot.webp` once you drop screenshots in public/portfolio/
const projects = [
  {
    name: "Northpoint Plumbing",
    type: "Service business",
    description: "Local plumbing company. 3-page site with emergency contact, service area map, and 24h call form.",
    tags: ["Multi-page", "Service business", "Lead form"],
    accent: "from-[#7C5CFF] to-[#22D3EE]",
  },
  {
    name: "Harvest & Hearth",
    type: "Restaurant",
    description: "Farm-to-table restaurant. One scrolling page with menu, hours, gallery, and reservation link.",
    tags: ["Single-page", "Restaurant", "Photo gallery"],
    accent: "from-[#FF6B4A] to-[#7C5CFF]",
  },
  {
    name: "Birchwood Studio",
    type: "Boutique",
    description: "Custom furniture studio. Portfolio-style site that shows the work and books consultations.",
    tags: ["Multi-page", "Portfolio", "Booking"],
    accent: "from-[#22D3EE] to-[#FF6B4A]",
  },
];
---

<section class="section" id="portfolio">
  <div class="container-page">
    <div class="flex flex-wrap items-end justify-between gap-6 max-w-4xl">
      <div>
        <span class="eyebrow reveal">Recent work</span>
        <h2 class="reveal mt-6 text-4xl sm:text-5xl md:text-6xl font-display font-semibold">
          Real businesses, <span class="gradient-text">real results.</span>
        </h2>
      </div>
      <a href="#contact" class="reveal text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors inline-flex items-center gap-2 group">
        Want yours next?
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>

    <div class="mt-16 grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {projects.map((p) => (
        <article class="reveal card overflow-hidden group">
          <div class={`relative aspect-[4/3] overflow-hidden bg-gradient-to-br ${p.accent}`}>
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(255,255,255,0.2),transparent_50%)]"></div>
            <!-- Mock browser chrome -->
            <div class="absolute top-4 left-4 right-4 h-6 rounded-md bg-black/30 backdrop-blur-sm flex items-center gap-1.5 px-2">
              <span class="h-2 w-2 rounded-full bg-white/40"></span>
              <span class="h-2 w-2 rounded-full bg-white/40"></span>
              <span class="h-2 w-2 rounded-full bg-white/40"></span>
            </div>
            <!-- Mock content blocks -->
            <div class="absolute inset-x-6 bottom-6 space-y-2">
              <div class="h-3 w-3/4 rounded-full bg-white/30"></div>
              <div class="h-3 w-1/2 rounded-full bg-white/20"></div>
              <div class="h-8 w-28 rounded-full bg-white/40 mt-4"></div>
            </div>
            <!-- Hover overlay -->
            <div class="absolute inset-0 bg-[var(--color-bg)]/0 group-hover:bg-[var(--color-bg)]/20 transition-colors duration-500"></div>
          </div>
          <div class="p-6">
            <p class="text-xs text-[var(--color-fg-dim)] uppercase tracking-[0.16em]">{p.type}</p>
            <h3 class="mt-2 text-xl font-display font-semibold">{p.name}</h3>
            <p class="mt-2 text-sm text-[var(--color-fg-muted)] leading-relaxed">{p.description}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {p.tags.map((t) => (
                <span class="text-xs px-2.5 py-1 rounded-full bg-[var(--color-bg-elevated)] border border-[var(--color-border)] text-[var(--color-fg-muted)]">{t}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

    <p class="mt-10 text-center text-sm text-[var(--color-fg-dim)] reveal">
      <em>Project mockups shown — real screenshots being added. Want to be next?</em>
    </p>
  </div>
</section>
