---
const stats = [
  { value: 2, suffix: "s", label: "Average load time", decimals: 1 },
  { value: 100, suffix: "%", label: "Mobile-first builds" },
  { value: 24, suffix: "h", label: "Quote turnaround" },
  { value: 0, suffix: "", label: "Hidden fees" },
];
---

<section class="border-y border-[var(--color-border)] bg-[var(--color-bg-surface)]/40 backdrop-blur-sm">
  <div class="container-page py-12 md:py-16">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-fg-dim)] text-center mb-10">
      What you get, by the numbers
    </p>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
      {stats.map((s) => (
        <div class="reveal text-center">
          <div class="font-display text-4xl md:text-5xl font-semibold gradient-text">
            <span data-count={s.value} data-count-decimals={s.decimals ?? 0}>0</span><span>{s.suffix}</span>
          </div>
          <div class="mt-2 text-sm text-[var(--color-fg-muted)]">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
