---
import Wordmark from "./Wordmark.astro";

const links = [
  { href: "#services", label: "Services" },
  { href: "#process", label: "Process" },
  { href: "#portfolio", label: "Work" },
  { href: "#pricing", label: "Pricing" },
  { href: "#faq", label: "FAQ" },
];
---

<header
  data-nav
  class="fixed top-0 left-0 right-0 z-40 transition-all duration-300"
>
  <div class="container-page">
    <div class="nav-inner mt-4 flex items-center justify-between gap-6 rounded-full border border-transparent px-4 py-2.5 transition-all duration-300">
      <Wordmark />

      <nav class="hidden md:flex items-center gap-1" aria-label="Primary">
        {links.map((l) => (
          <a
            href={l.href}
            class="px-4 py-2 text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors rounded-full"
          >
            {l.label}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-3">
        <a href="#contact" class="hidden sm:inline-flex btn btn-primary magnetic !py-2.5 !px-5 !text-sm">
          Book a call
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <button
          data-nav-toggle
          aria-expanded="false"
          aria-controls="nav-menu"
          class="md:hidden inline-flex h-10 w-10 items-center justify-center rounded-full border border-[var(--color-border-strong)] text-[var(--color-fg)]"
        >
          <span class="sr-only">Toggle menu</span>
          <svg class="open-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    data-nav-menu
    id="nav-menu"
    class="md:hidden fixed inset-0 top-[72px] bg-[var(--color-bg)]/95 backdrop-blur-xl pointer-events-none opacity-0 transition-opacity duration-300"
  >
    <nav class="container-page pt-8 flex flex-col gap-2" aria-label="Mobile primary">
      {links.map((l) => (
        <a href={l.href} class="text-2xl font-display py-3 border-b border-[var(--color-border)]">
          {l.label}
        </a>
      ))}
      <a href="#contact" class="btn btn-primary mt-6 self-start">Book a call</a>
    </nav>
  </div>
</header>

<style>
  [data-nav].nav-scrolled .nav-inner {
    background-color: rgba(10, 14, 26, 0.72);
    border-color: var(--color-border);
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
  }
  [data-nav-menu].is-open {
    opacity: 1;
    pointer-events: auto;
  }
</style>
