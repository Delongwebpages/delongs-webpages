---
---

<section class="relative min-h-[100svh] flex items-center pt-32 pb-20 overflow-hidden" id="top">
  <!-- Animated background layers -->
  <div class="grid-bg" aria-hidden="true"></div>
  <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[120%] aspect-square max-w-[1200px]">
      <div class="absolute inset-0 rounded-full bg-[radial-gradient(circle_at_30%_30%,rgba(124,92,255,0.45),transparent_50%)] blur-3xl animate-blob-1"></div>
      <div class="absolute inset-0 rounded-full bg-[radial-gradient(circle_at_70%_60%,rgba(34,211,238,0.35),transparent_50%)] blur-3xl animate-blob-2"></div>
      <div class="absolute inset-0 rounded-full bg-[radial-gradient(circle_at_50%_80%,rgba(255,107,74,0.28),transparent_50%)] blur-3xl animate-blob-3"></div>
    </div>
  </div>

  <div class="container-page relative">
    <div class="max-w-4xl">
      <div class="hero-fade">
        <span class="eyebrow">
          <span class="relative flex h-2 w-2">
            <span class="absolute inset-0 rounded-full bg-[var(--color-accent-2)] animate-ping opacity-75"></span>
            <span class="relative rounded-full h-2 w-2 bg-[var(--color-accent-2)]"></span>
          </span>
          Available for new builds — May 2026
        </span>
      </div>

      <h1 class="mt-6 text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-display font-semibold leading-[1.02] tracking-tight">
        <span class="hero-line block">Websites that</span>
        <span class="hero-line block gradient-text">actually sell.</span>
      </h1>

      <p class="hero-fade mt-8 max-w-2xl text-lg sm:text-xl text-[var(--color-fg-muted)] leading-relaxed">
        Handcrafted, lightning-fast websites for small businesses. One developer, one clear price, one honest conversation. Built right the first time — and maintained for as long as you own the doors.
      </p>

      <div class="hero-fade mt-10 flex flex-col sm:flex-row gap-3 sm:items-center">
        <a href="#contact" class="btn btn-primary magnetic">
          Book a free 15-minute call
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="#pricing" class="btn btn-ghost">
          See pricing
        </a>
      </div>

      <div class="hero-fade mt-12 flex flex-wrap items-center gap-x-8 gap-y-4 text-sm text-[var(--color-fg-dim)]">
        <div class="flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="text-[var(--color-accent-2)]"><path d="M20 6 9 17l-5-5"/></svg>
          <span>$1,000 per page — no surprises</span>
        </div>
        <div class="flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="text-[var(--color-accent-2)]"><path d="M20 6 9 17l-5-5"/></svg>
          <span>You own the code</span>
        </div>
        <div class="flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="text-[var(--color-accent-2)]"><path d="M20 6 9 17l-5-5"/></svg>
          <span>Built in days, not months</span>
        </div>
      </div>
    </div>

    <!-- Scroll cue -->
    <div class="hero-fade absolute bottom-8 left-1/2 -translate-x-1/2 hidden md:flex flex-col items-center gap-2 text-xs text-[var(--color-fg-dim)] uppercase tracking-[0.2em]">
      <span>Scroll</span>
      <span class="h-10 w-px bg-gradient-to-b from-[var(--color-fg-dim)] to-transparent animate-pulse"></span>
    </div>
  </div>
</section>

<style>
  @keyframes blob1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(20px, -20px) scale(1.05); }
  }
  @keyframes blob2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-30px, 20px) scale(1.1); }
  }
  @keyframes blob3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(15px, 30px) scale(0.95); }
  }
  .animate-blob-1 { animation: blob1 18s ease-in-out infinite; }
  .animate-blob-2 { animation: blob2 22s ease-in-out infinite; }
  .animate-blob-3 { animation: blob3 26s ease-in-out infinite; }

  @media (prefers-reduced-motion: reduce) {
    .animate-blob-1, .animate-blob-2, .animate-blob-3 { animation: none; }
  }
</style>
