---
import ContactForm from "./ContactForm.astro";
---

<section class="section relative overflow-hidden" id="contact">
  <!-- Dramatic background -->
  <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
    <div class="absolute inset-0 grid-bg opacity-60"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[140%] aspect-square max-w-[1400px]">
      <div class="absolute inset-0 rounded-full bg-[radial-gradient(circle,rgba(124,92,255,0.3),transparent_55%)] blur-3xl animate-blob-slow"></div>
      <div class="absolute inset-0 rounded-full bg-[radial-gradient(circle_at_70%_30%,rgba(255,107,74,0.18),transparent_50%)] blur-3xl animate-blob-slow-2"></div>
    </div>
  </div>

  <div class="container-page relative">
    <div class="grid lg:grid-cols-5 gap-12 items-start">
      <div class="lg:col-span-2">
        <span class="eyebrow reveal">Let's talk</span>
        <h2 class="reveal mt-6 text-4xl sm:text-5xl md:text-6xl font-display font-semibold leading-[1.05]">
          Ready for a website that <span class="gradient-text">actually works?</span>
        </h2>
        <p class="reveal mt-6 text-lg text-[var(--color-fg-muted)] leading-relaxed">
          Tell me about your business. I'll send a fixed quote within 24 hours. If we're not a fit, I'll tell you straight — and point you to someone who is.
        </p>
        <div class="reveal mt-8 space-y-4 text-sm">
          <div class="flex items-center gap-3 text-[var(--color-fg-muted)]">
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-[var(--color-bg-elevated)] border border-[var(--color-border-strong)]">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="text-[var(--color-accent-2)]"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </span>
            Reply within 24 hours, every time
          </div>
          <div class="flex items-center gap-3 text-[var(--color-fg-muted)]">
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-[var(--color-bg-elevated)] border border-[var(--color-border-strong)]">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="text-[var(--color-accent-2)]"><path d="M20 6 9 17l-5-5"/></svg>
            </span>
            No obligation, no pitch deck
          </div>
          <div class="flex items-center gap-3 text-[var(--color-fg-muted)]">
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-[var(--color-bg-elevated)] border border-[var(--color-border-strong)]">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="text-[var(--color-accent-2)]"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </span>
            Quote in 24 hours, fixed price
          </div>
        </div>
      </div>

      <div class="lg:col-span-3">
        <ContactForm />
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes blobSlow {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(30px, -30px) scale(1.1); }
  }
  @keyframes blobSlow2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-40px, 30px) scale(0.95); }
  }
  .animate-blob-slow { animation: blobSlow 24s ease-in-out infinite; }
  .animate-blob-slow-2 { animation: blobSlow2 30s ease-in-out infinite; }
  @media (prefers-reduced-motion: reduce) {
    .animate-blob-slow, .animate-blob-slow-2 { animation: none; }
  }
</style>
