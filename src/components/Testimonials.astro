---
// PLACEHOLDER testimonials — replace with real ones once collected
const quotes = [
  {
    quote: "I called three agencies and got three quotes I couldn't make sense of. Cullen sent a fixed price the next morning. Site was live two weeks later.",
    name: "Owner",
    role: "Local plumbing business",
  },
  {
    quote: "It loads. That's not a joke — my old Wix site took 8 seconds to open on a phone. Customers actually wait now. Calls went up.",
    name: "Owner",
    role: "Family restaurant",
  },
  {
    quote: "He answered the phone every time I called. That alone is worth the monthly plan.",
    name: "Founder",
    role: "Custom furniture studio",
  },
];
---

<section class="section">
  <div class="container-page">
    <div class="max-w-3xl">
      <span class="eyebrow reveal">What clients say</span>
      <h2 class="reveal mt-6 text-4xl sm:text-5xl md:text-6xl font-display font-semibold">
        The phone rings, <span class="gradient-text">and they pick up.</span>
      </h2>
    </div>

    <div class="mt-16 grid md:grid-cols-3 gap-5">
      {quotes.map((q) => (
        <figure class="reveal card p-7 flex flex-col">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor" class="text-[var(--color-accent)]/40 mb-5" aria-hidden="true">
            <path d="M9.5 8c-1.93 0-3.5 1.57-3.5 3.5S7.57 15 9.5 15c.66 0 1.18.52 1.18 1.18 0 .66-.52 1.18-1.18 1.18C5.92 17.36 3 14.44 3 10.86 3 7.27 5.92 4.36 9.5 4.36c.5 0 .9.4.9.9s-.4.9-.9.9zm9 0c-1.93 0-3.5 1.57-3.5 3.5s1.57 3.5 3.5 3.5c.66 0 1.18.52 1.18 1.18 0 .66-.52 1.18-1.18 1.18-3.58 0-6.5-2.92-6.5-6.5 0-3.58 2.92-6.5 6.5-6.5.5 0 .9.4.9.9s-.4.9-.9.9z"/>
          </svg>
          <blockquote class="flex-1 text-[var(--color-fg)] leading-relaxed">"{q.quote}"</blockquote>
          <figcaption class="mt-6 pt-5 border-t border-[var(--color-border)]">
            <div class="font-medium">{q.name}</div>
            <div class="text-sm text-[var(--color-fg-muted)]">{q.role}</div>
          </figcaption>
        </figure>
      ))}
    </div>

    <p class="mt-10 text-center text-sm text-[var(--color-fg-dim)] italic reveal">
      Sample testimonials shown — real ones added as projects ship.
    </p>
  </div>
</section>
