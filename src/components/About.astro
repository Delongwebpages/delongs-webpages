---
---

<section class="section" id="about">
  <div class="container-page">
    <div class="grid lg:grid-cols-5 gap-12 items-center">
      <div class="lg:col-span-2">
        <div class="reveal relative aspect-square max-w-md mx-auto rounded-2xl overflow-hidden border border-[var(--color-border-strong)]">
          <!-- Photo placeholder — drop /public/about/portrait.jpg or .webp and update src below -->
          <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-bg-elevated)] via-[var(--color-bg-surface)] to-[var(--color-bg)]"></div>
          <div class="absolute inset-0 grid-bg opacity-50"></div>
          <div class="absolute inset-0 flex items-center justify-center text-center p-8">
            <div>
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mx-auto mb-4 text-[var(--color-fg-dim)]" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M2 21a10 10 0 0 1 20 0"/></svg>
              <p class="text-sm text-[var(--color-fg-dim)] uppercase tracking-[0.16em]">Photo placeholder</p>
              <p class="text-xs text-[var(--color-fg-dim)] mt-1">Drop in <code>/public/about/portrait.jpg</code></p>
            </div>
          </div>
          <!-- Once you add the photo, replace the divs above with:
          <img src="/about/portrait.jpg" alt="Cullen, founder of Delong Webpages" class="absolute inset-0 w-full h-full object-cover" loading="lazy" decoding="async" />
          -->
        </div>
      </div>

      <div class="lg:col-span-3">
        <span class="eyebrow reveal">Meet your developer</span>
        <h2 class="reveal mt-6 text-4xl sm:text-5xl md:text-6xl font-display font-semibold">
          Hi, I'm <span class="gradient-text">Cullen.</span>
        </h2>
        <p class="reveal mt-6 text-lg text-[var(--color-fg-muted)] leading-relaxed">
          I build websites for small businesses — the kind of businesses that actually pick up the phone. No agency, no junior handoff, no dashboard between you and the work. You email me, I write you back. You call me, I answer.
        </p>
        <p class="reveal mt-4 text-lg text-[var(--color-fg-muted)] leading-relaxed">
          I built this to be the kind of web shop I'd want to hire if I owned a restaurant or ran a trade. Honest pricing. Fast turnaround. Code you actually own. And a person who's still around six months later.
        </p>

        <div class="reveal mt-10 grid grid-cols-2 gap-4 max-w-md">
          <div class="border-l-2 border-[var(--color-accent)] pl-4">
            <div class="text-sm text-[var(--color-fg-muted)]">Based in</div>
            <div class="font-medium">United States</div>
          </div>
          <div class="border-l-2 border-[var(--color-accent-2)] pl-4">
            <div class="text-sm text-[var(--color-fg-muted)]">Get in touch</div>
            <div class="font-medium text-sm"><a href="#contact" class="hover:underline">Contact form</a></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
