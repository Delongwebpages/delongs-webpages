---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<a href="/" class={`inline-flex items-center gap-2 group ${className}`} aria-label="Delong Webpages — home">
  <span class="relative inline-flex h-7 w-7 items-center justify-center rounded-md bg-[var(--color-bg-elevated)] border border-[var(--color-border-strong)] overflow-hidden">
    <span class="absolute inset-0 bg-gradient-to-br from-[var(--color-accent)] to-[var(--color-accent-2)] opacity-90"></span>
    <span class="relative font-display font-bold text-base text-[var(--color-bg)]">D</span>
  </span>
  <span class="font-display text-lg font-semibold tracking-tight">
    Delong Webpages
  </span>
</a>
