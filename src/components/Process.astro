---
const steps = [
  {
    n: "01",
    title: "We talk",
    desc: "A free 15-minute call. You tell me about your business, I ask the right questions. No sales pitch, no upsell. We'll know in 15 minutes if we're a fit.",
    duration: "Day 1",
  },
  {
    n: "02",
    title: "I quote",
    desc: "Within 24 hours: a fixed quote with page count, timeline, and what's included. Pick a maintenance plan now or later — it's optional.",
    duration: "Within 24h",
  },
  {
    n: "03",
    title: "I build",
    desc: "I send a draft within a week. You give feedback. I revise. We launch when you're happy — not before. No ghosting, no surprises.",
    duration: "1–3 weeks",
  },
  {
    n: "04",
    title: "We launch",
    desc: "Site goes live on lightning-fast hosting. You get the keys. If you picked a plan, I keep it humming. If not, you can come back anytime.",
    duration: "Launch day",
  },
];
---

<section class="section bg-[var(--color-bg-surface)]/40 border-y border-[var(--color-border)]" id="process">
  <div class="container-page">
    <div class="max-w-3xl">
      <span class="eyebrow reveal">How it works</span>
      <h2 class="reveal mt-6 text-4xl sm:text-5xl md:text-6xl font-display font-semibold">
        Four steps, <span class="gradient-text">honest timelines</span>, zero runaround.
      </h2>
    </div>

    <ol class="mt-16 grid md:grid-cols-2 lg:grid-cols-4 gap-5">
      {steps.map((s, i) => (
        <li class="reveal relative card p-7">
          <div class="flex items-baseline justify-between mb-4">
            <span class="font-display text-5xl font-semibold gradient-text">{s.n}</span>
            <span class="text-xs uppercase tracking-[0.16em] text-[var(--color-fg-dim)]">{s.duration}</span>
          </div>
          <h3 class="text-xl font-display font-semibold">{s.title}</h3>
          <p class="mt-3 text-sm text-[var(--color-fg-muted)] leading-relaxed">{s.desc}</p>
          {i < steps.length - 1 && (
            <div class="hidden lg:block absolute top-1/2 -right-3 w-6 h-px bg-gradient-to-r from-[var(--color-border-strong)] to-transparent" aria-hidden="true"></div>
          )}
        </li>
      ))}
    </ol>
  </div>
</section>
